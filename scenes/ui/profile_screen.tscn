[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/profile_screen.gd" id="1"]

[node name="ProfileScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.078, 0.09, 0.11, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 32
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 32
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="TitleRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Margin/VBox/TitleRow"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(0.4, 0.7, 1, 1)
text = "PROFILE"

[node name="Spacer" type="Control" parent="Margin/VBox/TitleRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="BackButton" type="Button" parent="Margin/VBox/TitleRow"]
layout_mode = 2
custom_minimum_size = Vector2(120, 40)
text = "Back"

[node name="Main" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 32

[node name="Left" type="VBoxContainer" parent="Margin/VBox/Main"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="NameRow" type="HBoxContainer" parent="Margin/VBox/Main/Left"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="NameEdit" type="LineEdit" parent="Margin/VBox/Main/Left/NameRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Player name"
max_length = 20

[node name="ApplyNameButton" type="Button" parent="Margin/VBox/Main/Left/NameRow"]
layout_mode = 2
custom_minimum_size = Vector2(110, 0)
text = "Apply"

[node name="LevelLabel" type="Label" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Level 1"

[node name="XpBar" type="ProgressBar" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 20)
show_percentage = false

[node name="XpLabel" type="Label" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.75, 0.8, 1)
text = "EXP 0 / 300"

[node name="StatsTitle" type="Label" parent="Margin/VBox/Main/Left"]
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 0.7, 1, 1)
text = "Statistics"

[node name="StatsLabel" type="Label" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
text = ""

[node name="LoadoutTitle" type="Label" parent="Margin/VBox/Main/Left"]
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 0.7, 1, 1)
text = "Loadout"

[node name="LoadoutLabel" type="Label" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
text = ""

[node name="Right" type="VBoxContainer" parent="Margin/VBox/Main"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="OwnedTitle" type="Label" parent="Margin/VBox/Main/Right"]
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 0.7, 1, 1)
text = "Inventory (select to equip)"

[node name="OwnedList" type="ItemList" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="EquipButton" type="Button" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 44)
disabled = true
text = "Equip selected"

[connection signal="pressed" from="Margin/VBox/TitleRow/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Left/NameRow/ApplyNameButton" to="." method="_on_apply_name_pressed"]
[connection signal="item_selected" from="Margin/VBox/Main/Right/OwnedList" to="." method="_on_owned_list_item_selected"]
[connection signal="pressed" from="Margin/VBox/Main/Right/EquipButton" to="." method="_on_equip_button_pressed"]
