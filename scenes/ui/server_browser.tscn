[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/server_browser.gd" id="1"]

[node name="ServerBrowser" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.078, 0.09, 0.11, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 32
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 32
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="TitleRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Margin/VBox/TitleRow"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(0.4, 0.7, 1, 1)
text = "SERVER LIST"

[node name="Spacer" type="Control" parent="Margin/VBox/TitleRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="BackButton" type="Button" parent="Margin/VBox/TitleRow"]
layout_mode = 2
custom_minimum_size = Vector2(120, 40)
text = "Back"

[node name="Main" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 24

[node name="Left" type="VBoxContainer" parent="Margin/VBox/Main"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="ServerList" type="ItemList" parent="Margin/VBox/Main/Left"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="Buttons" type="HBoxContainer" parent="Margin/VBox/Main/Left"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="JoinButton" type="Button" parent="Margin/VBox/Main/Left/Buttons"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(140, 40)
text = "Join"

[node name="RemoveButton" type="Button" parent="Margin/VBox/Main/Left/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(140, 40)
text = "Remove"

[node name="Right" type="VBoxContainer" parent="Margin/VBox/Main"]
layout_mode = 2
custom_minimum_size = Vector2(320, 0)
theme_override_constants/separation = 8

[node name="ConnectTitle" type="Label" parent="Margin/VBox/Main/Right"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.75, 0.8, 1)
text = "Connect / save a server"

[node name="NameEdit" type="LineEdit" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Server name (optional)"

[node name="AddressEdit" type="LineEdit" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Address (e.g. 127.0.0.1)"

[node name="PortEdit" type="LineEdit" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Port (default 7777)"

[node name="ConnectRow" type="HBoxContainer" parent="Margin/VBox/Main/Right"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="DirectConnectButton" type="Button" parent="Margin/VBox/Main/Right/ConnectRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 40)
text = "Connect"

[node name="AddButton" type="Button" parent="Margin/VBox/Main/Right/ConnectRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 40)
text = "Save to list"

[node name="HostBox" type="VBoxContainer" parent="Margin/VBox/Main/Right"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 8

[node name="Sep" type="HSeparator" parent="Margin/VBox/Main/Right/HostBox"]
layout_mode = 2

[node name="HostTitle" type="Label" parent="Margin/VBox/Main/Right/HostBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.75, 0.8, 1)
text = "Host a game"

[node name="HostConfigLabel" type="Label" parent="Margin/VBox/Main/Right/HostBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.55, 0.6, 0.66, 1)
text = ""
autowrap_mode = 2

[node name="HostNameEdit" type="LineEdit" parent="Margin/VBox/Main/Right/HostBox"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Server name"

[node name="HostPortEdit" type="LineEdit" parent="Margin/VBox/Main/Right/HostBox"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Port (default 7777)"

[node name="HostButton" type="Button" parent="Margin/VBox/Main/Right/HostBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "Host"

[node name="StatusLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.85, 0.4, 1)
text = ""

[connection signal="pressed" from="Margin/VBox/TitleRow/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Left/Buttons/JoinButton" to="." method="_on_join_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Left/Buttons/RemoveButton" to="." method="_on_remove_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Right/ConnectRow/DirectConnectButton" to="." method="_on_direct_connect_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Right/ConnectRow/AddButton" to="." method="_on_add_pressed"]
[connection signal="pressed" from="Margin/VBox/Main/Right/HostBox/HostButton" to="." method="_on_host_pressed"]
