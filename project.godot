[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="players"
2d_physics/layer_3="projectiles"
2d_physics/layer_4="pickups"

[physics]

2d/default_gravity=1600.0

[rendering]

